{
  "name": "iqro-learn",
  "version": "1.0.0",
  "license": "0BSD",
  "private": true,
  "main": "index.tsx",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "prebuild": "node scripts/generate-build-info.js",
    "build:web": "node scripts/generate-build-info.js && npx expo export --platform web",
    "deploy:web": "node scripts/generate-build-info.js && npx expo export --platform web && npx wrangler pages deploy dist --project-name=iqro-learn",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex dev --once",
    "postexport": "node -e \"const fs=require('fs'),p=require('path');function cp(s,d){try{if(fs.statSync(s).isDirectory()){fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>cp(p.join(s,f),p.join(d,f)))}else{fs.mkdirSync(p.dirname(d),{recursive:true});fs.copyFileSync(s,d)}}catch(e){}}cp('dist/assets/node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts','dist/fonts');cp('public/_redirects','dist/_redirects');cp('public/_headers','dist/_headers')\"",
    "deploy:all": "node scripts/generate-build-info.js && npx convex dev --once && npx expo export --platform web && npm run postexport && npx wrangler pages deploy dist --project-name=iqro-learn"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.80",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "babel-preset-expo": "^55.0.14-canary-20260328-2049187",
    "convex": "^1.21.0",
    "expo": "^55.0.10-canary-20260328-2049187",
    "expo-clipboard": "^7.0.0",
    "expo-font": "^55.0.5-canary-20260328-2049187",
    "expo-linking": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "^5.0.0",
    "react-native-screens": "^4.0.0",
    "react-native-web": "~0.19.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~18.2.14",
    "typescript": "^5.1.3"
  }
}
